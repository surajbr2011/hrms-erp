# ─── Backend API ──────────────────────────────────────────────────────────────
# Full URL to the backend API (must include /api suffix)
# Local: http://localhost:5000/api
# Production example: https://hrms-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ─── Socket.io ────────────────────────────────────────────────────────────────
# Base URL to the backend (without /api)
# Local: http://localhost:5000
# Production example: https://hrms-api.onrender.com
VITE_SOCKET_URL=http://localhost:5000
