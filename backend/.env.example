# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Local example:  mongodb://127.0.0.1:27017/hrms_db
# Atlas example:  mongodb+srv://<user>:<password>@cluster.mongodb.net/hrms_db?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/hrms_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Use a strong random string minimum 32 chars: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://hrms.yourdomain.com,https://www.hrms.yourdomain.com
CLIENT_URL=http://localhost:5173
